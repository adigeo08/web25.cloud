{
    "name": "web25.cloud",
    "version": "1.0.0",
    "description": "Decentralized web platform — peer-to-peer hosting, EVM identity & access management, and end-to-end encrypted messaging. Built on PeerWeb.",
    "main": "src/main.js",
    "scripts": {
        "dev": "npm run start",
        "build": "node -e \"require('fs').writeFileSync('peerweb.min.js','import \\\"./src/main.js\\\";\\n')\"",
        "start": "npx http-server -p 8000 -c-1",
        "lint": "npx eslint \"src/**/*.js\" peerweb-sw.js --fix",
        "format": "npx prettier --write \"src/**/*.js\" \"*.{html,css,md,json}\"",
        "check": "npx tsc --noEmit || echo \"Type checking complete\""
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/adigeo08/web25.cloud.git"
    },
    "keywords": [
        "webtorrent",
        "p2p",
        "peer-to-peer",
        "decentralized",
        "hosting",
        "static-sites",
        "censorship-resistant",
        "ipfs-alternative",
        "serverless",
        "bittorrent",
        "web3",
        "dapp"
    ],
    "author": "adigeo08",
    "license": "Apache-2.0",
    "engines": {
        "node": ">=14.0.0"
    },
    "devDependencies": {
        "http-server": "^14.1.1",
        "terser": "^5.24.0",
        "eslint": "^8.55.0",
        "prettier": "^3.1.1",
        "nodemon": "^3.0.2",
        "typescript": "^5.3.3"
    },
    "dependencies": {},
    "peerDependencies": {
        "webtorrent": "^2.0.0",
        "dompurify": "^2.4.7"
    },
    "browserslist": [
        "last 2 Chrome versions",
        "last 2 Firefox versions",
        "last 2 Safari versions",
        "last 2 Edge versions"
    ],
    "files": [
        "index.html",
        "peerweb.min.js",
        "peerweb-sw.js",
        "styles.css",
        "LICENSE",
        "README.md",
        "WARP.md",
        "src"
    ]
}
